{
    "compilerOptions": {
        "target": "es6",
        "lib": ["ESNext"],
        "sourceMap": false,
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "isolatedModules": false,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "declaration": false,
        "noImplicitAny": false,
        "removeComments": true,
        "noLib": false,
        "strict": true,
        "strictFunctionTypes": false,
        "preserveConstEnums": true,
        "esModuleInterop": true,
        "paths": { "*": ["./*"] },
        "allowJs": true,
        "types": ["vitest/globals"]
    }
}
